samian:fs_1000080_4e9d57 a lado:Findspot,
        lado:Location,
        crm:E53_Place ;
    rdfs:label "Pottery Shop II" ;
    crm:P4_has_time-span samian:ts_1000080_4e9d57 ;
    crm:P89_falls_within samian:loc_ds_1000080 ;
    skos:notation "pottery_shop_ii" .

samian:fs_1000080_e4a7d3 a lado:Findspot,
        lado:Location,
        crm:E53_Place ;
    rdfs:label "Pottery Shop I" ;
    crm:P4_has_time-span samian:ts_1000080_e4a7d3 ;
    crm:P89_falls_within samian:loc_ds_1000080 ;
    skos:notation "pottery_shop_i" .

samian:fs_1000136_32f514 a lado:Findspot,
        lado:Location,
        crm:E53_Place ;
    rdfs:label "Second Fire" ;
    crm:P4_has_time-span samian:ts_1000136_32f514 ;
    crm:P89_falls_within samian:loc_ds_1000136 ;
    skos:notation "second_fire" .

samian:fs_1000136_83ac45 a lado:Findspot,
        lado:Location,
        crm:E53_Place ;
    rdfs:label "New Fresh Wharf: quay" ;
