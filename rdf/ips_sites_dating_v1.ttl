samian:DatingModel_v1 a lado:DatingModel ;
    rdfs:label "Virtual fuzzy year, volume-based k (v1)"@en ;
    lado:eraConvention "historical" ;
    lado:excludedDatemax 120,
        150,
        260 ;
    lado:fuzzinessDivisor 12 ;
    lado:kMax 1.5 ;
    lado:kMin 0.5 ;
    lado:tau 20.0 ;
    lado:volumeWeight 1.0 ;
    rdfs:comment "eff = m +/- k*sigma. sigma aus Varianzzerlegung sqrt(AVG(w^2/12) + VAR(Mitten)). k rein volumenbasiert. Das Intervall ist ein archaeologisch motiviertes 'virtual fuzzy year', ausdruecklich KEIN Konfidenzintervall."@de .

samian:trs_ips_year a time:TRS ;
    rdfs:label "IPS signed year scale"@en ;
    rdfs:comment "Durchgehende Zahlengerade vorzeichenbehafteter Jahreszahlen, auf der die Quell-Query rechnet (eff = m +/- k*sigma). Wie negative Werte als Kalenderjahre zu lesen sind, sagt lado:eraConvention am Datierungsmodell; die daraus abgeleiteten Kalenderlabels stehen als time:inXSDgYear an den Instants. Die Position selbst wird NICHT umgerechnet, weil eine Verschiebung nur der negativen Werte die Skala bei 0 zerreissen wuerde."@de ;
    skos:closeMatch <http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> .

samian:IPSDatedSitesExporter a prov:SoftwareAgent ;
    rdfs:label "ips_rdf_export.py"@en .

samian:dataset_sites_dating_v1_2026-07-22 a dcat:Dataset,
        prov:Entity ;
    lado:identifierScheme "sha256(NFC(trim(findspot)))[0:6], je Fundplatz-ID" ;
    dcterms:created "2026-07-22T16:37:23+00:00"^^xsd:dateTime ;
    dcterms:issued "2026-07-22"^^xsd:date ;
    dcterms:source "Samian Research / IPS, tbldistribution + tblpotter + v_discoverysite" ;
    dcterms:title "Archaeological findspots dated by samian potters' stamps"@en ;
    rdfs:comment "Datierter Snapshot. Die Fundstellen- und Zeitspannen-URIs sind bewusst NICHT versioniert: sie bezeichnen dauerhaft dieselbe Fundstelle bzw. deren jeweils aktuelle Datierung. Aendern sich die Quelldaten, aendern sich die Werte unter derselben URI. Wer einen konkreten Stand zitieren will, zitiert diesen Datensatz."@de ;
    owl:versionInfo "2026-07-22" ;
    prov:wasAttributedTo samian:IPSDatedSitesExporter .

